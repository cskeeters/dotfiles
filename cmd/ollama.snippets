snippet ollama_start ollama: Start Ollama
	ollama serve
snippet ollama_list ollama: List Models
	ollama list
snippet ollama_run ollama: Run Model (Chat)
	ollama run ${1:ollama_local_models()}
snippet ollama_stop ollama: Stop Model
	ollama stop ${1:ollama_running_models()}
snippet ollama_ps ollama: List Running Models
	ollama ps
snippet ollama_logs ollama: Show Server Logs
	tail -f /var/log/ollama/stderr
snippet ollama_rm ollama: Remove Model
	ollama rm ${1:ollama_local_models()}
snippet ollama_update ollama: Update Models
	ollama list | sed '1d' | awk '{print $1}' | xargs -I {} ollama pull {}

snippet ollama_show_modelfile ollama: Show Modelfile
	ollama show ${1:ollama_local_models()} --modelfile

snippet ollama_model_blob ollama: Model Blob
	gguf-dump --json --no-tensors ~/.ollama/models/blobs/$(cat ~/.ollama/models/manifests/registry.ollama.ai/library/${1:ollama_local_manifest()} | \
	  jq -r '.layers[] | select (.mediaType == "application/vnd.ollama.image.model") | .digest' | \
	  tr ':' '-') | jq -C | less

snippet ollama_proxy ollama: Proxy Server (for Debugging)
	llm_proxy

snippet llama_proxy llama: Proxy Server (for Debugging)
	llm_proxy -p 11535

snippet mlx_proxy mlx: Proxy Server (for Debugging)
	llm_proxy -p 11635

snippet ollama_extract_template ollama: Extract Template
	BLOB=$(cat ~/.ollama/models/manifests/registry.ollama.ai/library/${1:ollama_local_manifest()} | \
	  jq -r '.layers[] | select (.mediaType == "application/vnd.ollama.image.template") | .digest' | \
	  tr ':' '-')
	
	echo Using blob: $BLOB
	
	python3 - <<EOF
	import gguf
	import os
	
	path = os.path.expanduser("~/.ollama/models/blobs/$BLOB")
	reader = gguf.GGUFReader(path)
	for name, field in reader.fields.items():
		if 'chat_template' in name:
			# Convert the parts to a string
			data = bytes(field.parts[-1].tolist())
			print(data.decode('utf-8'))
	EOF

snippet ollama_model_architecture: ollama: Output Model Architecture
	gguf-dump --json ${1:ollama_model_blob_path()} | jq -r '.metadata["general.architecture"].value'

snippet oterm_run oterm: Open oterm TUI frontend
	oterm
