{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-websearch-cited@1.2.0"
  ],
  // "formatter": false,
  // "lsp": false,
  "mcp": {
      "context7": {
          "type": "remote",
          "url": "https://mcp.context7.com/mcp",
          "headers": {
              "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
          },
          "enabled": true
      }
  },
  "provider": {
    "hyde": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Hyde (Ollama)",
      "options": {
        "baseURL": "http://192.168.20.11:11434/v1",
        "timeout": 60000000
      },
      "models": {
        "qwen3.5:35b": {
            "name": "qwen3.5:35b"
        },
        "qwen3.5:latest": {
            "name": "qwen3.5:27b"
        },
        "qwen3.6:35b-a3b-bf16": {
            "name": "qwen3.6:35b-a3b-bf16"
        },
        "qwen3.6:35b-a3b-q8_0": {
            "name": "qwen3.6:35b-a3b-q8_0"
        },
        "glm-4.7-flash:latest": {
            "name": "glm-4.7-flash:latest"
        },
        "nemotron-3-super:latest": {
            "name": "nemotron-3-super:latest"
        },
        "nemotron-cascade-2:latest": {
            "name": "nemotron-cascade-2:latest"
        },
        "gpt-oss:120b": {
            "name": "gpt-oss:120b"
        },
        "gpt-oss:20b": {
            "name": "gpt-oss:20b"
        },
        "omnicoder-2-9b:latest": {
            "name": "omnicoder-2-9b:latest"
        },
        "phi4:latest": {
            "name": "phi4:latest"
        },
        "phi4-reasoning:latest": {
            "name": "phi4-reasoning:latest"
        },
        "llama3.3:latest": {
            "name": "llama3.3:latest"
        },
        "deepseek-r1:70b": {
            "name": "deepseek-r1:70b"
        },
        "gemma3:27b": {
            "name": "gemma3:27b"
        },
        "mistral-small3.2:latest": {
            "name": "mistral-small3.2:latest"
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        // "baseURL": "http://localhost:8888/v1",
        "timeout": 60000000
      },
      "models": {
        "qwen3-coder-next:latest": {
            "name": "qwen3-coder-next:latest"
        },
        "Qwen3-Coder:30b": {
            "name": "qwen3-coder"
            // "reasoning": true,
            // "tool_call": true
        },
        "glm-4.7-flash:latest": {
            "name": "glm-4.7-flash:latest"
        },
        "SimonPu/Qwen3-Coder:30B-Instruct_Q4_K_XL": {
            "name": "qwen3-coder_Q4"
        },
        "gpt-oss:20b": {
            "name": "gpt-oss:20b"
        },
        "qwen2.5-coder:latest": {
            "name": "qwen2.5-coder:latest"
        },
        "llama3.3:latest": {
            "name": "llama3.3:latest"
        }
        //"devstral-small-2:latest": {
        //    // slow!
        //    "name": "devstral-small-2:latest"
        //}
      }
    },
    "llama.cpp": {
        "npm": "@ai-sdk/openai-compatible",
        "name": "llama.cpp",
        "options": {
            "baseURL": "http://localhost:11534/v1",
            "timeout": 60000000
        },
        "models": {
            "Qwen3-Next-80B-A3B-Instruct-GGUF:Q4_K_XL": {
                "name": "Qwen3-Next-80B-A3B-Instruct-GGUF:Q4_K_XL"
            }
        }
    },
    "mlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MLX (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11634/v1"
      },
      "models": {
        "Qwen3-Coder-30B-A3B-Instruct-4bit": {
          "name": "Qwen3-Coder-30B-A3B-Instruct-4bit"
        },
        "Qwen3-Coder-30B-A3B-Instruct-6bit": {
          "name": "Qwen3-Coder-30B-A3B-Instruct-6bit"
        },
        "Qwen3-Coder-Next-4bit": {
          "name": "Qwen3-Coder-Next-4bit"
        }
      }
    }
  },
  "model": "ollama/qwen3-coder",
  "permission": {
    "websearch": "allow",
    "websearch_cited": "allow", // depending on the plugin's tool name
    "external_directory": {
      "/tmp/**": "allow",
      "/private/tmp/**": "allow"
    }
  }
}
